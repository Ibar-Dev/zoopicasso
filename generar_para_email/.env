# Ruta principal donde se guardan las facturas generadas.
# Puede ser absoluta (ej: C:\\Facturas) o relativa al proyecto.
FACTURAS_DIR=facturas

# Opcional: ruta de copia secundaria en Windows.
# Si se deja vacio, se intentara usar Documents/Documentos automaticamente.
FACTURAS_DIR_WINDOWS=

# ── CONFIGURACIÓN DE LOGGING ───────────────────────────────────────────────────
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Archivo de log (relativo a generar_para_email/ o ruta absoluta)
LOG_FILE=logs/app.log

# Tamaño máximo del archivo de log antes de rotación, en bytes (default: 5242880 = 5MB)
LOG_MAX_BYTES=5242880

# Cantidad de archivos de log rotados a mantener (default: 5)
LOG_BACKUP_COUNT=5

# ── BACKUP AUTOMÁTICO ──────────────────────────────────────────────────────────
# Carpeta donde se guardan los backups. Puede ser:
#   - Una ruta local:              /backups/facturas
#   - Una carpeta de red montada:  /mnt/nas/facturas
#   - Una carpeta de Google Drive: /home/usuario/GoogleDrive/Backups
# Dejar vacío para desactivar el backup automático.
BACKUP_DIR=

# Cada cuántas horas se hace el backup automático (defecto: 24)
BACKUP_INTERVALO_HORAS=24

# Cuántas copias ZIP se conservan antes de borrar las más antiguas (defecto: 7)
BACKUP_RETENER=7

# ── CONFIGURACIÓN DE RUTAS PARA CIERRES AUTOMÁTICOS ────────────────────────────
# Rutas UNC para carpetas compartidas en red del cliente (DESKTOP-4UE66NT)
# Se utiliza \\ en lugar de \ porque es el formato correcto para rutas UNC en Windows

# Cierre de Mañana (06:00-14:00)
# Se ejecuta automáticamente a las 14:00 diariamente
CIERRE_MANANA_DIR=\\DESKTOP-4UE66NT\C$\Documentos\facturas_cierre_mannanas

# Cierre de Tarde (14:00-22:00)
# Se ejecuta automáticamente a las 22:00 diariamente
CIERRE_TARDE_DIR=\\DESKTOP-4UE66NT\C$\Documentos\facturas_cierre_tardes

# Cierre del Día Completo (06:00-22:00)
# Se ejecuta automáticamente a las 22:05 diariamente (5 min después de cierre de tarde)
CIERRE_DIA_COMPLETO_DIR=\\DESKTOP-4UE66NT\C$\Documentos\facturas_cierre_dia

# Cierre del Mes
# Se ejecuta automáticamente a las 22:00 del último día del mes
CIERRE_MES_DIR=\\DESKTOP-4UE66NT\C$\Documentos\facturas_cierre_mes

# Nota: Si estas variables no se configuran, los cierres se guardarán en:
#   - CIERRES_DIR (variable genérica, si existe)
#   - $HOME/Descargas (fallback final del sistema)

